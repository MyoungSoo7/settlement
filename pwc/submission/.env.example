# trusted-ceo-agent 외부 API 키 — 이 파일을 .env 로 복사해 값을 채우세요.
#   로컬 개발/테스트:      cp .env.example .env  (모든 CLI/MCP 가 상위 폴더의 .env 를 자동 탐색)
#   Codex 플러그인 설치 후: cp .env.example ~/.codex/.env
#     (Codex 플러그인 MCP 서버는 셸 env 를 상속하지 않으므로, 설치 캐시에서
#      상향 탐색이 닿는 ~/.codex/.env 가 유일하게 확실한 위치입니다 — 실측 확인)
# 키가 없는 항목은 해당 축만 생략되고 나머지 진단은 그대로 동작합니다.

# DART 공시·재무제표 (기본 모드 필수 — 발급: https://opendart.fss.or.kr)
DART_API_KEY=

# 국세청 사업자등록 상태조회/진위확인 — 기업 식별 게이트 (발급: https://www.data.go.kr)
# 없으면 사업자번호 체크섬 검증만 수행하고 국세청 조회는 생략합니다.
DATA_GO_KR_API_KEY=

# 한국은행 ECOS 기준금리·국고채·환율·물가 (발급: https://ecos.bok.or.kr)
# 없으면 거시 컨텍스트만 생략됩니다.
ECOS_API_KEY=

# 네이버 뉴스 검색 — 정성 보조 신호 (발급: https://developers.naver.com)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# LLM Judge (선택 — briefing-eval --judge / demo-e2e --judge)
# 없으면 Judge 는 자동 skip 되고 규칙 채점만 수행합니다.
# BRIEFING_JUDGE_PROVIDER=off|gemini|anthropic 으로 강제 지정 가능.
GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
