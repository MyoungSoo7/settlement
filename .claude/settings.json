{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"%CLAUDE_PROJECT_DIR%/settlement-copilot/hooks/guards/check-write.mjs\" 2>nul || node \"$CLAUDE_PROJECT_DIR/settlement-copilot/hooks/guards/check-write.mjs\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"%CLAUDE_PROJECT_DIR%/settlement-copilot/hooks/guards/check-command.mjs\" 2>nul || node \"$CLAUDE_PROJECT_DIR/settlement-copilot/hooks/guards/check-command.mjs\""
          }
        ]
      }
    ]
  }
}
