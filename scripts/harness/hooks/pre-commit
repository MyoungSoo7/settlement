#!/bin/sh
# Repo-tracked pre-commit — survives fresh clone (unlike .git/hooks/).
# Enable once with: node scripts/harness/install-hooks.mjs   (sets core.hooksPath)
#
# Layer 1 (mandatory, plugin-independent): harness core-invariant guard.
ROOT="$(git rev-parse --show-toplevel)" || exit 1
node "$ROOT/scripts/harness/guard.mjs" --staged || exit 1

# Layer 2 (best-effort): copilot plugin guards, only if the plugin is present.
for g in \
  "hackathon/settlement-copilot/hooks/guards/pre-commit.mjs" \
  "hackathon/invest-copilot/hooks/guards/pre-commit.mjs" ; do
  p="$ROOT/$g"
  [ -f "$p" ] && { node "$p" || exit 1; }
done

exit 0
