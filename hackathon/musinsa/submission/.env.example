# musinsa-fashion-first 외부 API 키 — 이 파일을 .env 로 복사해 값을 채우세요.
#   로컬 개발/테스트:      cp .env.example .env  (이 폴더 또는 상위 폴더)
#   Codex 플러그인 설치 후: cp .env.example ~/.codex/.env
#     (Codex 플러그인 MCP 서버는 셸 env 를 상속하지 않으므로, 설치 캐시에서
#      상향 탐색이 닿는 ~/.codex/.env 가 유일하게 확실한 위치입니다 — 실측 확인)
# 필요한 키는 네이버 1쌍뿐입니다. 키가 없어도 스킬은 사용자에게 사실을 직접 묻는
# 방식으로 우아하게 강등되고, 옷장 복기 데모(src/data/sample)는 키 없이 완전 동작합니다.

# 네이버 OpenAPI — 쇼핑 검색(상품·가격 분포) + 뉴스 검색(평판·트렌드) 공용
# 발급: https://developers.naver.com (애플리케이션 등록 → '검색' API 추가, 즉시 발급)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# (선택) 같은 앱에 '데이터랩' API 를 추가 등록하면 datalab_shopping_trend
# (쇼핑인사이트 실클릭 시계열)가 자동 활성화됩니다. 미등록이어도 트렌드 축은
# 뉴스 언급량 시계열(buzz_trend)로 동작합니다.

# (선택) 공공데이터포털 — 날씨×코디 축 + 공식 리콜 DB 축 (키 하나 공용)
# 발급: https://www.data.go.kr 가입 → "기상청_단기예보 조회서비스" 와
#       "공정거래위원회_화장품(·공산품) 리콜정보" 각각 활용신청(자동승인)
#       → 마이페이지의 일반 인증키. 리콜 API 는 제공기관(소비자24) 반영까지
#       시간이 걸릴 수 있으며, 그동안 도구가 안내 에러로 알려줍니다.
#       없으면 해당 축만 우아하게 강등됩니다.
DATA_GO_KR_API_KEY=

# (선택) 소비자24 공식 리콜 DB 전용 인증번호 — consumer.go.kr 로그인 → Open API
# 활용신청으로 발급. 설정 시 리콜 축이 이 키를 우선 사용합니다
# (data.go.kr LINK 신청만으로는 소비자24에 키가 등록되지 않을 수 있음 — 실측).
CONSUMER24_API_KEY=
