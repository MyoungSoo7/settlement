codex
CSV 안의 한글 필드는 콘솔에서 깨져 보이지만 숫자, 날짜, ID, 색/사이즈/트리거 구분은 분석 가능합니다. 상품명은 오독 위험이 있어 최종 답변에서는 `item_id`, 날짜, 가격, 할인율, 착용 횟수를 중심으로 근거를 제시하겠습니다.
exec
"C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe" -Command '$closet = Import-Csv src/data/sample/closet.csv; $purchases = Import-Csv src/data/sample/purchases.csv; 
"closet_count=$($closet.Count) purchase_count=$($purchases.Count)";
"-- totals --";
$ownedTotal = ($closet | Measure-Object -Property price_paid -Sum).Sum; $purchaseTotal = ($purchases | Measure-Object -Property price_paid -Sum).Sum; $returnedTotal = ($purchases | Where-Object returned -eq '"'Y' | Measure-Object -Property price_paid -Sum).Sum; \"owned_paid="'$ownedTotal purchased_paid=$purchaseTotal returned_paid=$returnedTotal";
"-- closet per item --";
$closet | ForEach-Object { $w=[int]$_.worn_count_6mo; $paid=[decimal]$_.price_paid; [pscustomobject]@{id=$_.item_id; date=$_.purchase_date; paid=[int]$paid; disc=[int]$_.discount_pct; worn=$w; cpw= if($w -gt 0){[math]::Round($paid/$w,0)} else {'"'INF'}; category="'$_.category; sub=$_.subcategory; brand=$_.brand; color=$_.color; size=$_.size; last=$_.last_worn} } | Sort-Object worn, paid | Format-Table -AutoSize;
"-- by discount band --";
$closet | Group-Object { if([int]$_.discount_pct -ge 55){'"'55%+'} elseif([int]"'$_.discount_pct -ge 30){'"'30-54%'} elseif([int]"'$_.discount_pct -gt 0){'"'1-29%'} else {'0%'} } | ForEach-Object { "'$items=$_.Group; $paid=($items|Measure price_paid -Sum).Sum; $worn=($items|Measure worn_count_6mo -Sum).Sum; [pscustomobject]@{band=$_.Name; count=$_.Count; paid=[int]$paid; worn=[int]$worn; avg_worn=[math]::Round($worn/$_.Count,1); cpw=if($worn -gt 0){[math]::Round($paid/$worn,0)}else{'"'INF'} } } | Sort-Object band | Format-Table -AutoSize;
\"-- by trigger --\";
"'$purchases | Group-Object trigger | ForEach-Object { $items=$_.Group; $paid=($items|Measure price_paid -Sum).Sum; $returns=($items|Where returned -eq '"'Y').Count; [pscustomobject]@{trigger="'$_.Name; count=$_.Count; paid=[int]$paid; returns=$returns; return_rate=[math]::Round($returns/$_.Count*100,1); avg_discount=[math]::Round((($items|Measure discount_pct -Average).Average),1)} } | Format-Table -AutoSize;
"-- dead/low wear --";
$closet | Where-Object {[int]$_.worn_count_6mo -le 2} | ForEach-Object {[pscustomobject]@{id=$_.item_id; date=$_.purchase_date; paid=[int]$_.price_paid; disc=[int]$_.discount_pct; worn=[int]$_.worn_count_6mo; last=$_.last_worn; brand=$_.brand; item=$_.item_name}} | Format-Table -AutoSize;
"-- repeat top black L tops? --";
$closet | Group-Object category,color,size | ForEach-Object { $items=$_.Group; $paid=($items|Measure price_paid -Sum).Sum; $worn=($items|Measure worn_count_6mo -Sum).Sum; [pscustomobject]@{key=$_.Name; count=$_.Count; paid=[int]$paid; worn=[int]$worn; avg_worn=[math]::Round($worn/$_.Count,1); ids=($items.item_id -join '"',')} } | Sort-Object count -Descending | Format-Table -AutoSize;
\"-- returns --\";
