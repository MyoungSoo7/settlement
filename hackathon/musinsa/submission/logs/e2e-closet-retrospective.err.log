codex
로컬 PowerShell 버전이 null 병합 연산자를 지원하지 않아 스크립트만 호환 문법으로 바꿔 재실행합니다. 데이터 파일은 그대로 두고 읽기만 하고 있습니다.
exec
"C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe" -Command '$closet = Import-Csv src/data/sample/closet.csv; $purchases = Import-Csv src/data/sample/purchases.csv;
function Key($r){ $d=$r.purchase_date; if(-not $d){$d=$r.order_date}; "$d|$($r.brand)|$($r.item_name)|$($r.price_paid)" }
$closetByKey=@{}; foreach($c in $closet){ $closetByKey[(Key $c)]=$c }
"-- trigger stats corrected --";
