codex
초기 집계를 보면 “세일 알림으로 산 고할인 상의”가 가장 강한 후보입니다. 반품 집계는 PowerShell 필터 구문을 보정해서 다시 계산하고, 구매 트리거별 착용 효율까지 연결해 보겠습니다.
exec
"C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe" -Command '$closet = Import-Csv src/data/sample/closet.csv; $purchases = Import-Csv src/data/sample/purchases.csv;
function Key($r){ "$($r.purchase_date ?? $r.order_date)|$($r.brand)|$($r.item_name)|$($r.price_paid)" }
$closetByKey=@{}; foreach($c in $closet){ $closetByKey[(Key $c)]=$c }
"-- trigger stats corrected --";
$purchases | Group-Object trigger | ForEach-Object { $items=$_.Group; $paid=($items|Measure-Object price_paid -Sum).Sum; $ret=@($items|Where-Object { $_.returned -eq '"'Y' }); [pscustomobject]@{trigger="'$_.Name; count=$_.Count; paid=[int]$paid; returns=$ret.Count; return_paid=[int](($ret|Measure-Object price_paid -Sum).Sum); return_rate=[math]::Round($ret.Count/$_.Count*100,1); avg_discount=[math]::Round((($items|Measure-Object discount_pct -Average).Average),1)} } | Format-Table -AutoSize;
"-- trigger + retained wear --";
$purchases | Where-Object { $_.returned -ne '"'Y' } | ForEach-Object { "'$k=Key $_; if($closetByKey.ContainsKey($k)){ $c=$closetByKey[$k]; [pscustomobject]@{trigger=$_.trigger; paid=[int]$_.price_paid; discount=[int]$_.discount_pct; worn=[int]$c.worn_count_6mo; id=$c.item_id} } else { [pscustomobject]@{trigger=$_.trigger; paid=[int]$_.price_paid; discount=[int]$_.discount_pct; worn=$null; id='"'NO_MATCH'} } } | Group-Object trigger | ForEach-Object { "'$items=$_.Group; $paid=($items|Measure-Object paid -Sum).Sum; $worn=($items|Measure-Object worn -Sum).Sum; [pscustomobject]@{trigger=$_.Name; retained=$_.Count; paid=[int]$paid; worn=[int]$worn; avg_worn=[math]::Round($worn/$_.Count,1); cpw=if($worn -gt 0){[math]::Round($paid/$worn,0)}else{'"'INF'}; ids=("'$items.id -join '"',')} } | Format-Table -AutoSize;
\"-- useful vs low buckets --\";
"'$dead=@($closet|Where-Object {[int]$_.worn_count_6mo -le 2}); $low=@($closet|Where-Object {[int]$_.worn_count_6mo -le 3}); $active=@($closet|Where-Object {[int]$_.worn_count_6mo -ge 15});
[pscustomobject]@{bucket='"'worn<=2'; count="'$dead.Count; paid=[int](($dead|Measure price_paid -Sum).Sum); pct_items=[math]::Round($dead.Count/$closet.Count*100,1); pct_paid=[math]::Round((($dead|Measure price_paid -Sum).Sum)/(($closet|Measure price_paid -Sum).Sum)*100,1); worn=[int](($dead|Measure worn_count_6mo -Sum).Sum)} | Format-List;
[pscustomobject]@{bucket='"'worn<=3'; count="'$low.Count; paid=[int](($low|Measure price_paid -Sum).Sum); pct_items=[math]::Round($low.Count/$closet.Count*100,1); pct_paid=[math]::Round((($low|Measure price_paid -Sum).Sum)/(($closet|Measure price_paid -Sum).Sum)*100,1); worn=[int](($low|Measure worn_count_6mo -Sum).Sum)} | Format-List;
[pscustomobject]@{bucket='"'worn>=15'; count="'$active.Count; paid=[int](($active|Measure price_paid -Sum).Sum); pct_items=[math]::Round($active.Count/$closet.Count*100,1); pct_paid=[math]::Round((($active|Measure price_paid -Sum).Sum)/(($closet|Measure price_paid -Sum).Sum)*100,1); worn=[int](($active|Measure worn_count_6mo -Sum).Sum)} | Format-List;' in C:\Users\iamip\IdeaProjects\kubenetis\settlement\hackathon\musinsa\submission
