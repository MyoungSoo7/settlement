  const sr = parseToolPayload(series);
  check('?쇱씠釉? BASE_RATE 愿痢≪튂 ??1',
    sr?.count >= 1 && typeof sr?.latest?.value === 'number',
    JSON.stringify({ count: sr?.count, latest: sr?.latest }));
} else {
  console.log('  (???놁쓬 ???쇱씠釉?寃利??앸왂)');
}

finish();


