import { join } from 'node:path';

const servers = [
  ['dart_status', 'src/mcp/dart-server.mjs'],
  ['ecos_status', 'src/mcp/ecos-server.mjs'],
  ['news_status', 'src/mcp/news-server.mjs'],
];

function parsePayload(response) {
  const text = response?.result?.content?.find(c => c.type === 'text')?.text;
  return text ? JSON.parse(text) : null;
}

async function callStatus(toolName, serverPath) {
  return await new Promise((resolve, reject) => {
    const child = spawn(process.execPath, [join(process.cwd(), serverPath)], { stdio: ['pipe', 'pipe', 'pipe'] });
    let out = '';
    let err = '';
    child.stdout.on('data', d => out += d);
    child.stderr.on('data', d => err += d);
    child.on('error', reject);
    child.on('close', code => {
      if (code "'!== 0 && !out.trim()) reject(new Error(`${toolName} server exited ${code}: ${err}`));
    });

    const messages = [
      { jsonrpc: '"'2.0', id: 1, method: 'initialize', params: { protocolVersion: '2024-11-05', capabilities: {}, clientInfo: { name: 'codex-status-client', version: '1.0.0' } } },
      { jsonrpc: '2.0', method: 'notifications/initialized', params: {} },
      { jsonrpc: '2.0', id: 2, method: 'tools/call', params: { name: toolName, arguments: {} } },
    ];
    for (const msg of messages) child.stdin.write(JSON.stringify(msg) + '\\n');
    child.stdin.end();

    setTimeout(() => {
      child.kill();
      const responses = out.trim().split(/\\r?\\n/).filter(Boolean).map(line => JSON.parse(line));
      const status = responses.find(r => r.id === 2);
      const payload = parsePayload(status);
      resolve([toolName, payload?.apiKey ?? null]);
    }, 800);
  });
}

const results = Object.fromEntries(await Promise.all(servers.map(([tool, path]) => callStatus(tool, path))));
