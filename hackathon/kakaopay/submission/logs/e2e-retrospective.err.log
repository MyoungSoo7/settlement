exec
"C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe" -Command "@'
"'$trades = Import-Csv src/data/sample/trades.csv
$holdings = Import-Csv src/data/sample/holdings.csv

'"'By ticker trade summary:'
"'$trades | Group-Object ticker | ForEach-Object {
  $ticker = $_.Name
  $rows = $_.Group | Sort-Object date
  $buys = $rows | Where-Object side -eq '"'BUY'
  "'$sells = $rows | Where-Object side -eq '"'SELL'
  "'$buyQty = ($buys | Measure-Object -Property qty -Sum).Sum
  $buyAmt = ($buys | ForEach-Object { [decimal]$_.qty * [decimal]$_.price } | Measure-Object -Sum).Sum
  $sellQty = ($sells | Measure-Object -Property qty -Sum).Sum
  $sellAmt = ($sells | ForEach-Object { [decimal]$_.qty * [decimal]$_.price } | Measure-Object -Sum).Sum
  [pscustomobject]@{
    ticker=$ticker; trades=$rows.Count; buy_qty=$buyQty; buy_amount=$buyAmt; avg_buy=[math]::Round($buyAmt / [decimal]$buyQty,2); sell_qty=$sellQty; sell_amount=$sellAmt
  }
} | Format-Table -AutoSize

'"'Holdings P/L:'
"'$holdings | ForEach-Object {
  $qty=[decimal]$_.qty; $avg=[decimal]$_.avg_price; $cur=[decimal]$_.current_price
  [pscustomobject]@{ticker=$_.ticker; qty=$qty; avg=$avg; current=$cur; invested=$qty*$avg; value=$qty*$cur; unrealized=($cur-$avg)*$qty; return_pct=[math]::Round((($cur/$avg)-1)*100,2)}
} | Format-Table -AutoSize

'"'All trades with amounts:'
"'$trades | Sort-Object date | ForEach-Object { [pscustomobject]@{date=$_.date;ticker=$_.ticker;side=$_.side;qty=$_.qty;price=$_.price;amount=([decimal]$_.qty*[decimal]$_.price)} } | Format-Table -AutoSize
'"'@ | powershell -NoProfile -Command -" in C:\Users\iamip\IdeaProjects\kubenetis\settlement\hackathon\kakaopay\submission
