# kakaopay-invest-companion 외부 API 키 — 이 파일을 .env 로 복사해 값을 채우세요.
#   로컬 개발/테스트:      cp .env.example .env  (이 폴더 또는 상위 폴더)
#   Codex 플러그인 설치 후: cp .env.example ~/.codex/.env
#     (Codex 플러그인 MCP 서버는 셸 env 를 상속하지 않으므로, 설치 캐시에서
#      상향 탐색이 닿는 ~/.codex/.env 가 유일하게 확실한 위치입니다 — 실측 확인)
# 키가 없는 항목은 해당 데이터 축만 우아하게 강등됩니다 — 스킬은 사용자에게
# 사실을 직접 질문하는 방식으로 계속 동작하고, 스모크 테스트는 프로토콜 검증만 수행합니다.

# DART 공시·재무제표 — 악재 실체·펀더멘털 훼손 확인 축 (발급: https://opendart.fss.or.kr)
DART_API_KEY=

# 한국은행 ECOS 기준금리·국고채·환율·물가 — 시장 요인 vs 종목 요인 분리 축 (발급: https://ecos.bok.or.kr)
ECOS_API_KEY=

# 네이버 뉴스 검색 — "이 뉴스가 악재인가요?" 실보도 확인 축 (발급: https://developers.naver.com)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
