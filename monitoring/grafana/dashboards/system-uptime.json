{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "title": "Lemuel — System (Uptime · CPU · Memory · HTTP)",
  "uid": "lemuel-system-uptime",
  "tags": ["lemuel", "system", "uptime", "resources"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-24h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "가동 시간 (Uptime)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "현재 가동 시간 (인스턴스별)",
      "datasource": "Prometheus",
      "description": "프로세스 부팅 후 경과 시간. 값이 갑자기 0 으로 떨어지면 재시작.",
      "gridPos": { "h": 7, "w": 10, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 300 },
              { "color": "green", "value": 3600 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "process_uptime_seconds{job=~\"lemuel.*\"}",
          "legendFormat": "{{application}} ({{instance}})"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "가동 시간 추이 — 재시작 시 톱니처럼 0 으로 리셋",
      "datasource": "Prometheus",
      "gridPos": { "h": 7, "w": 14, "x": 10, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "process_uptime_seconds{job=~\"lemuel.*\"}",
          "legendFormat": "{{application}} ({{instance}})"
        }
      ]
    },
    {
      "id": 4,
      "type": "row",
      "title": "가동률 & 재시작",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 8 },
      "collapsed": false
    },
    {
      "id": 5,
      "type": "stat",
      "title": "가동률 (최근 24h, %)",
      "datasource": "Prometheus",
      "description": "scrape 타깃이 살아있던(up=1) 시간 비율.",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 9 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 95 },
              { "color": "green", "value": 99 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "avg_over_time(up{job=~\"lemuel.*\"}[24h]) * 100",
          "legendFormat": "{{application}} ({{instance}})"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "타깃 생사 (up: 1=살아있음, 0=다운)",
      "datasource": "Prometheus",
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 9 },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0, "max": 1 },
        "overrides": []
      },
      "targets": [
        {
          "expr": "up{job=~\"lemuel.*\"}",
          "legendFormat": "{{application}} ({{instance}})"
        }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "재시작 횟수 (최근 24h)",
      "datasource": "Prometheus",
      "description": "process_start_time_seconds 변경 횟수 = 프로세스 재기동 수.",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 9 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "changes(process_start_time_seconds{job=~\"lemuel.*\"}[24h])",
          "legendFormat": "{{application}} ({{instance}})"
        }
      ]
    },
    {
      "id": 8,
      "type": "row",
      "title": "리소스 & API — CPU / 메모리 / 요청량 (운영 판단 기준 포함)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "collapsed": false
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "CPU 사용률 — process(JVM) vs system(호스트)",
      "datasource": "Prometheus",
      "description": "정상: process < 60%. 경고: 70% 이상 5분 지속. system 이 높은데 process 가 낮으면 동거 컨테이너 경합 의심.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.85 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "process_cpu_usage{job=~\"lemuel.*\"}",
          "legendFormat": "{{application}} process"
        },
        {
          "expr": "system_cpu_usage{job=~\"lemuel.*\"}",
          "legendFormat": "{{application}} system"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "JVM Heap 메모리 — used vs max",
      "datasource": "Prometheus",
      "description": "used 가 max 에 붙어 톱니(GC 후에도 안 내려감)면 누수/용량 부족. 경고: heap 사용률 80% 이상 지속.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
      "fieldConfig": { "defaults": { "unit": "bytes", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (application) (jvm_memory_used_bytes{job=~\"lemuel.*\", area=\"heap\"})",
          "legendFormat": "{{application}} heap used"
        },
        {
          "expr": "sum by (application) (jvm_memory_max_bytes{job=~\"lemuel.*\", area=\"heap\"})",
          "legendFormat": "{{application}} heap max"
        }
      ]
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Heap 사용률 (%)",
      "datasource": "Prometheus",
      "description": "정상 < 70%, 경고 70~85%, 위험 85% 이상(Full GC 빈발·OOM 임박).",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 25 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum by (application) (jvm_memory_used_bytes{job=~\"lemuel.*\", area=\"heap\"}) / sum by (application) (jvm_memory_max_bytes{job=~\"lemuel.*\", area=\"heap\"}) * 100",
          "legendFormat": "{{application}}"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "API 요청량 (req/s) & 5xx 비율",
      "datasource": "Prometheus",
      "description": "http_server_requests_seconds_count 기반 TPS. 5xx 비율 정상 < 1%, 경고 1% 이상 5분 지속.",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 25 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "min": 0 },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "/5xx 비율/" },
            "properties": [
              { "id": "unit", "value": "percentunit" },
              { "id": "custom.axisPlacement", "value": "right" }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "sum by (application) (rate(http_server_requests_seconds_count{job=~\"lemuel.*\"}[1m]))",
          "legendFormat": "{{application}} req/s"
        },
        {
          "expr": "sum by (application) (rate(http_server_requests_seconds_count{job=~\"lemuel.*\", status=~\"5..\"}[1m])) / sum by (application) (rate(http_server_requests_seconds_count{job=~\"lemuel.*\"}[1m]))",
          "legendFormat": "{{application}} 5xx 비율"
        }
      ]
    }
  ]
}
