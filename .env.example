# Database Configuration
POSTGRES_USER=
POSTGRES_PASSWORD=

# Elasticsearch Configuration
ELASTICSEARCH_USER=
ELASTICSEARCH_PASSWORD=

# JWT Configuration
JWT_ISSUER=
JWT_SECRET=
JWT_TTL_SECONDS=3600

# Mail Configuration (Gmail 예시)
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
SUPPORT_EMAIL=

# Application Configuration
APP_BASE_URL=
ENVIRONMENT=

# Slack Configuration (선택사항)
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=
SLACK_ALERTS_ENABLED=

# Security Scanning Tokens
SNYK_TOKEN=
SONAR_TOKEN=

# 한국은행 ECOS Open API 인증키 (economics-service 지표 수집용, 미설정 시 시드 데이터만 사용)
ECOS_API_KEY=

# 공공데이터포털 금융위 주식시세정보 인증키(Decoding 키) (market-service 시세 수집용, 미설정 시 시드 데이터만 사용)
# ⚠️ 키 발급만으로는 동작하지 않음 — data.go.kr 에서 "금융위원회_주식시세정보" API 를
#    검색해 **활용신청 → 승인**(자동승인, 수 분~1시간) 후부터 호출 가능. 승인 전엔 403 Forbidden.
KRX_API_KEY=

# 공공데이터포털 인증키(Decoding 키) (common-data-service 범용 수집용 — 계정당 1개로 활용신청한 모든 API 공용, 미설정 시 시드 데이터만 사용)
DATA_GO_KR_API_KEY=

# Anthropic Messages API 키 — company-service 감성분석(provider=llm) + ai-service 챗봇 공용.
# 미설정 시: 감성분석은 키워드 폴백, 챗봇 채팅은 503(이력 조회는 정상)
ANTHROPIC_API_KEY=
